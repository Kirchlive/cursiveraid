<Ui xmlns="http://www.blizzard.com/wow/ui/">

	<!-- Load the options UI logic first -->
	<Script file="CursiveOptionsUI.lua"/>

	<!-- Main Options Frame -->
	<Frame name="CursiveOptionsFrame" parent="UIParent" frameStrata="DIALOG" movable="true" enableMouse="true" clampedToScreen="true" hidden="true" toplevel="true">
		<Size x="450" y="550"/>
		<Anchors>
			<Anchor point="CENTER"/>
		</Anchors>
		<Backdrop bgFile="Interface\Tooltips\UI-Tooltip-Background" edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
			<EdgeSize val="16"/>
			<TileSize val="16"/>
			<BackgroundInsets left="5" right="5" top="5" bottom="5"/>
			<Color r="0" g="0" b="0" a="0.85"/>
		</Backdrop>
		<Layers>
			<Layer level="ARTWORK">
				<FontString name="CursiveOptionsTitle" inherits="GameFontNormalLarge" text="Cursive Options">
					<Anchors>
						<Anchor point="TOP">
							<Offset x="0" y="-12"/>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<!-- Close Button -->
			<Button name="CursiveOptionsCloseButton" inherits="UIPanelCloseButton">
				<Anchors>
					<Anchor point="TOPRIGHT">
						<Offset x="-4" y="-4"/>
					</Anchor>
				</Anchors>
			</Button>

			<!-- Tab Buttons -->
			<Button name="CursiveTabGeneral" inherits="CursiveTabButtonTemplate">
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset x="12" y="-35"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnLoad>
						getglobal(this:GetName().."Text"):SetText("General")
					</OnLoad>
					<OnClick>
						CursiveOpts.SelectTab(1)
					</OnClick>
				</Scripts>
			</Button>
			<Button name="CursiveTabDisplay" inherits="CursiveTabButtonTemplate">
				<Anchors>
					<Anchor point="LEFT" relativeTo="CursiveTabGeneral" relativePoint="RIGHT">
						<Offset x="-4" y="0"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnLoad>
						getglobal(this:GetName().."Text"):SetText("Display")
					</OnLoad>
					<OnClick>
						CursiveOpts.SelectTab(2)
					</OnClick>
				</Scripts>
			</Button>
			<Button name="CursiveTabFilters" inherits="CursiveTabButtonTemplate">
				<Anchors>
					<Anchor point="LEFT" relativeTo="CursiveTabDisplay" relativePoint="RIGHT">
						<Offset x="-4" y="0"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnLoad>
						getglobal(this:GetName().."Text"):SetText("Filters")
					</OnLoad>
					<OnClick>
						CursiveOpts.SelectTab(3)
					</OnClick>
				</Scripts>
			</Button>
			<Button name="CursiveTabDebuffs" inherits="CursiveTabButtonTemplate">
				<Anchors>
					<Anchor point="LEFT" relativeTo="CursiveTabFilters" relativePoint="RIGHT">
						<Offset x="-4" y="0"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnLoad>
						getglobal(this:GetName().."Text"):SetText("Debuffs")
					</OnLoad>
					<OnClick>
						CursiveOpts.SelectTab(4)
					</OnClick>
				</Scripts>
			</Button>

			<!-- ============================================= -->
			<!-- Panel 1: General                              -->
			<!-- ============================================= -->
			<Frame name="CursiveGeneralPanel" hidden="true">
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="CursiveOptionsFrame">
						<Offset x="12" y="-68"/>
					</Anchor>
					<Anchor point="BOTTOMRIGHT" relativeTo="CursiveOptionsFrame">
						<Offset x="-12" y="12"/>
					</Anchor>
				</Anchors>
				<Frames>
					<!-- Checkboxes -->
					<CheckButton name="CursiveOptEnabled" inherits="CursiveCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT">
								<Offset x="8" y="-4"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Enabled")
								this.tooltipText = "Enable or disable Cursive"
							</OnLoad>
							<OnClick>
								CursiveOpts.ToggleOption("enabled")
							</OnClick>
						</Scripts>
					</CheckButton>
					<CheckButton name="CursiveOptShowTitle" inherits="CursiveCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptEnabled" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="2"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Show Title")
								this.tooltipText = "Show the title of the frame"
							</OnLoad>
							<OnClick>
								CursiveOpts.ToggleOption("showtitle")
							</OnClick>
						</Scripts>
					</CheckButton>
					<CheckButton name="CursiveOptClickthrough" inherits="CursiveCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptShowTitle" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="2"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Allow Clickthrough")
								this.tooltipText = "Click through the frame to target mobs behind it"
							</OnLoad>
							<OnClick>
								CursiveOpts.ToggleOption("clickthrough")
							</OnClick>
						</Scripts>
					</CheckButton>
					<CheckButton name="CursiveOptShowBackdrop" inherits="CursiveCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptClickthrough" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="2"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Show Frame Background")
								this.tooltipText = "Toggle the frame background to help with positioning"
							</OnLoad>
							<OnClick>
								CursiveOpts.ToggleOption("showbackdrop")
							</OnClick>
						</Scripts>
					</CheckButton>

					<!-- Reset Frame Position Button -->
					<Button name="CursiveOptResetPos" inherits="UIPanelButtonTemplate2">
						<Size x="160" y="22"/>
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptShowBackdrop" relativePoint="BOTTOMLEFT">
								<Offset x="4" y="-6"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								this:SetText("Reset Frame Position")
							</OnLoad>
							<OnClick>
								CursiveOpts.ResetFramePosition()
							</OnClick>
						</Scripts>
					</Button>

					<!-- Sliders -->
					<Slider name="CursiveOptScale" inherits="CursiveSliderTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptResetPos" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="-28"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Scale")
								getglobal(this:GetName().."Low"):SetText("0.50")
								getglobal(this:GetName().."High"):SetText("2.00")
								this:SetMinMaxValues(0.50, 2.00)
								this:SetValueStep(0.05)
								this.tooltipText = "Scale of the Cursive frame"
							</OnLoad>
							<OnValueChanged>
								CursiveOpts.OnSliderChanged("scale", this, "%.2f")
							</OnValueChanged>
						</Scripts>
					</Slider>
					<Slider name="CursiveOptOpacity" inherits="CursiveSliderTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptScale" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="-24"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Opacity")
								getglobal(this:GetName().."Low"):SetText("0.00")
								getglobal(this:GetName().."High"):SetText("1.00")
								this:SetMinMaxValues(0.00, 1.00)
								this:SetValueStep(0.05)
								this.tooltipText = "Opacity of the Cursive frame"
							</OnLoad>
							<OnValueChanged>
								CursiveOpts.OnSliderChanged("opacity", this, "%.2f")
							</OnValueChanged>
						</Scripts>
					</Slider>
					<Slider name="CursiveOptMaxCurses" inherits="CursiveSliderTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptOpacity" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="-24"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Max Curses")
								getglobal(this:GetName().."Low"):SetText("1")
								getglobal(this:GetName().."High"):SetText("8")
								this:SetMinMaxValues(1, 8)
								this:SetValueStep(1)
								this.tooltipText = "Maximum number of curses shown per unit"
							</OnLoad>
							<OnValueChanged>
								CursiveOpts.OnSliderChanged("maxcurses", this, "%d")
							</OnValueChanged>
						</Scripts>
					</Slider>
					<Slider name="CursiveOptMaxRows" inherits="CursiveSliderTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptMaxCurses" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="-24"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Max Rows")
								getglobal(this:GetName().."Low"):SetText("1")
								getglobal(this:GetName().."High"):SetText("20")
								this:SetMinMaxValues(1, 20)
								this:SetValueStep(1)
								this.tooltipText = "Maximum number of rows"
							</OnLoad>
							<OnValueChanged>
								CursiveOpts.OnSliderChanged("maxrow", this, "%d")
							</OnValueChanged>
						</Scripts>
					</Slider>
					<Slider name="CursiveOptMaxCols" inherits="CursiveSliderTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptMaxRows" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="-24"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Max Columns")
								getglobal(this:GetName().."Low"):SetText("1")
								getglobal(this:GetName().."High"):SetText("20")
								this:SetMinMaxValues(1, 20)
								this:SetValueStep(1)
								this.tooltipText = "Maximum number of columns"
							</OnLoad>
							<OnValueChanged>
								CursiveOpts.OnSliderChanged("maxcol", this, "%d")
							</OnValueChanged>
						</Scripts>
					</Slider>
					<Slider name="CursiveOptSpacing" inherits="CursiveSliderTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptMaxCols" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="-24"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Spacing")
								getglobal(this:GetName().."Low"):SetText("0")
								getglobal(this:GetName().."High"):SetText("10")
								this:SetMinMaxValues(0, 10)
								this:SetValueStep(1)
								this.tooltipText = "Spacing between bars"
							</OnLoad>
							<OnValueChanged>
								CursiveOpts.OnSliderChanged("spacing", this, "%d")
							</OnValueChanged>
						</Scripts>
					</Slider>
				</Frames>
			</Frame>

			<!-- ============================================= -->
			<!-- Panel 2: Display                              -->
			<!-- ============================================= -->
			<Frame name="CursiveDisplayPanel" hidden="true">
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="CursiveOptionsFrame">
						<Offset x="12" y="-68"/>
					</Anchor>
					<Anchor point="BOTTOMRIGHT" relativeTo="CursiveOptionsFrame">
						<Offset x="-12" y="12"/>
					</Anchor>
				</Anchors>
				<Frames>
					<!-- Checkboxes -->
					<CheckButton name="CursiveOptInvertBars" inherits="CursiveCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT">
								<Offset x="8" y="-4"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Invert Bar Display")
								this.tooltipText = "Show sections in reverse order"
							</OnLoad>
							<OnClick>
								CursiveOpts.ToggleOption("invertbars")
							</OnClick>
						</Scripts>
					</CheckButton>
					<CheckButton name="CursiveOptExpandUp" inherits="CursiveCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptInvertBars" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="2"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Expand Bars Upwards")
								this.tooltipText = "Make bars expand upwards instead of downwards"
							</OnLoad>
							<OnClick>
								CursiveOpts.ToggleOption("expandupwards")
							</OnClick>
						</Scripts>
					</CheckButton>
					<CheckButton name="CursiveOptTargetArrow" inherits="CursiveCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptExpandUp" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="2"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Show Targeting Arrow")
								this.tooltipText = "Show targeting arrow indicator"
							</OnLoad>
							<OnClick>
								CursiveOpts.ToggleOption("showtargetindicator")
							</OnClick>
						</Scripts>
					</CheckButton>
					<CheckButton name="CursiveOptRaidIcons" inherits="CursiveCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptTargetArrow" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="2"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Show Raid Icons")
								this.tooltipText = "Show raid target icons"
							</OnLoad>
							<OnClick>
								CursiveOpts.ToggleOption("showraidicons")
							</OnClick>
						</Scripts>
					</CheckButton>
					<CheckButton name="CursiveOptHealthBar" inherits="CursiveCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptRaidIcons" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="2"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Show Health Bar")
								this.tooltipText = "Show unit health bars"
							</OnLoad>
							<OnClick>
								CursiveOpts.ToggleOption("showhealthbar")
							</OnClick>
						</Scripts>
					</CheckButton>
					<CheckButton name="CursiveOptUnitName" inherits="CursiveCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptHealthBar" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="2"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Show Unit Name")
								this.tooltipText = "Show unit name text"
							</OnLoad>
							<OnClick>
								CursiveOpts.ToggleOption("showunitname")
							</OnClick>
						</Scripts>
					</CheckButton>
					<CheckButton name="CursiveOptAlwaysTarget" inherits="CursiveCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptUnitName" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="2"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Always Show Current Target")
								this.tooltipText = "Always show current target at bottom of mob list"
							</OnLoad>
							<OnClick>
								CursiveOpts.ToggleOption("alwaysshowcurrenttarget")
							</OnClick>
						</Scripts>
					</CheckButton>
					<CheckButton name="CursiveOptDecimals" inherits="CursiveCheckButtonTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptAlwaysTarget" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="2"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Decimal Duration")
								this.tooltipText = "Show 1 decimal place for durations under 10s"
							</OnLoad>
							<OnClick>
								CursiveOpts.ToggleOption("curseshowdecimals")
							</OnClick>
						</Scripts>
					</CheckButton>

					<!-- Sliders -->
					<Slider name="CursiveOptHealthWidth" inherits="CursiveSliderTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptDecimals" relativePoint="BOTTOMLEFT">
								<Offset x="4" y="-24"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Health Bar Width")
								getglobal(this:GetName().."Low"):SetText("30")
								getglobal(this:GetName().."High"):SetText("150")
								this:SetMinMaxValues(30, 150)
								this:SetValueStep(5)
								this.tooltipText = "Width of the health bar"
							</OnLoad>
							<OnValueChanged>
								CursiveOpts.OnSliderChanged("healthwidth", this, "%d")
							</OnValueChanged>
						</Scripts>
					</Slider>
					<Slider name="CursiveOptHealthHeight" inherits="CursiveSliderTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptHealthWidth" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="-24"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Health Bar Height")
								getglobal(this:GetName().."Low"):SetText("10")
								getglobal(this:GetName().."High"):SetText("30")
								this:SetMinMaxValues(10, 30)
								this:SetValueStep(2)
								this.tooltipText = "Height of the health bar"
							</OnLoad>
							<OnValueChanged>
								CursiveOpts.OnSliderChanged("height", this, "%d")
							</OnValueChanged>
						</Scripts>
					</Slider>
					<Slider name="CursiveOptRaidIconSize" inherits="CursiveSliderTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptHealthHeight" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="-24"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Raid Icon Size")
								getglobal(this:GetName().."Low"):SetText("10")
								getglobal(this:GetName().."High"):SetText("30")
								this:SetMinMaxValues(10, 30)
								this:SetValueStep(1)
								this.tooltipText = "Size of raid target icons"
							</OnLoad>
							<OnValueChanged>
								CursiveOpts.OnSliderChanged("raidiconsize", this, "%d")
							</OnValueChanged>
						</Scripts>
					</Slider>
					<Slider name="CursiveOptCurseIconSize" inherits="CursiveSliderTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptRaidIconSize" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="-24"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Curse Icon Size")
								getglobal(this:GetName().."Low"):SetText("10")
								getglobal(this:GetName().."High"):SetText("30")
								this:SetMinMaxValues(10, 30)
								this:SetValueStep(1)
								this.tooltipText = "Size of curse icons"
							</OnLoad>
							<OnValueChanged>
								CursiveOpts.OnSliderChanged("curseiconsize", this, "%d")
							</OnValueChanged>
						</Scripts>
					</Slider>
					<Slider name="CursiveOptFontScale" inherits="CursiveSliderTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptCurseIconSize" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="-24"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Font Scale")
								getglobal(this:GetName().."Low"):SetText("0.50")
								getglobal(this:GetName().."High"):SetText("2.00")
								this:SetMinMaxValues(0.50, 2.00)
								this:SetValueStep(0.10)
								this.tooltipText = "Scale factor for all text"
							</OnLoad>
							<OnValueChanged>
								CursiveOpts.OnSliderChanged("fontscale", this, "%.2f")
							</OnValueChanged>
						</Scripts>
					</Slider>
					<Slider name="CursiveOptTextSize" inherits="CursiveSliderTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptFontScale" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="-24"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Name/HP Text Size")
								getglobal(this:GetName().."Low"):SetText("6")
								getglobal(this:GetName().."High"):SetText("20")
								this:SetMinMaxValues(6, 20)
								this:SetValueStep(1)
								this.tooltipText = "Font size for name and HP text"
							</OnLoad>
							<OnValueChanged>
								CursiveOpts.OnSliderChanged("textsize", this, "%d")
							</OnValueChanged>
						</Scripts>
					</Slider>
					<Slider name="CursiveOptCurseTimerSize" inherits="CursiveSliderTemplate">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="CursiveOptTextSize" relativePoint="BOTTOMLEFT">
								<Offset x="0" y="-24"/>
							</Anchor>
						</Anchors>
						<Scripts>
							<OnLoad>
								getglobal(this:GetName().."Text"):SetText("Curse Timer Size")
								getglobal(this:GetName().."Low"):SetText("6")
								getglobal(this:GetName().."High"):SetText("20")
								this:SetMinMaxValues(6, 20)
								this:SetValueStep(1)
								this.tooltipText = "Font size for curse timer text"
							</OnLoad>
							<OnValueChanged>
								CursiveOpts.OnSliderChanged("cursetimersize", this, "%d")
							</OnValueChanged>
						</Scripts>
					</Slider>
				</Frames>
			</Frame>

			<!-- ============================================= -->
			<!-- Panel 3: Filters                              -->
			<!-- ============================================= -->
			<Frame name="CursiveFiltersPanel" hidden="true">
