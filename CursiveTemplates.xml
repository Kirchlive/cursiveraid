<Ui xmlns="http://www.blizzard.com/wow/ui/">

	<!-- Checkbox template with hover highlight and tooltip preserve frame -->
	<CheckButton name="CursiveCheckButtonTemplate" inherits="OptionsCheckButtonTemplate" virtual="true">
		<Size x="32" y="32"/>
		<HitRectInsets left="0" right="-160" top="5" bottom="5"/>
		<Frames>
			<!-- Invisible frame that catches hover events over the text area even when checkbox is disabled -->
			<Frame name="$parentTooltipPreserve" enableMouse="true" hidden="true">
				<Size x="152" y="22"/>
				<Anchors>
					<Anchor point="LEFT" relativePoint="LEFT"/>
				</Anchors>
				<Scripts>
					<OnEnter>
						if this:GetParent().tooltipText then
							GameTooltip:SetOwner(this:GetParent(), "ANCHOR_RIGHT")
							GameTooltip:SetText(this:GetParent().tooltipText, nil, nil, nil, nil, 1)
						end
						if this:GetParent().tooltipRequirement then
							GameTooltip:AddLine(this:GetParent().tooltipRequirement, nil, nil, nil, 1)
							GameTooltip:Show()
						end
					</OnEnter>
					<OnLeave>
						GameTooltip:Hide()
					</OnLeave>
				</Scripts>
			</Frame>
		</Frames>
		<Scripts>
			<OnEnter>
				local text = getglobal(this:GetName().."Text")
				this.r, this.g, this.b = text:GetTextColor()
				text:SetTextColor(1, 1, 1)
				if this.tooltipText then
					GameTooltip:SetOwner(this, "ANCHOR_RIGHT")
					GameTooltip:SetText(this.tooltipText, nil, nil, nil, nil, 1)
				end
				if this.tooltipRequirement then
					GameTooltip:AddLine(this.tooltipRequirement, nil, nil, nil, 1)
					GameTooltip:Show()
				end
			</OnEnter>
			<OnLeave>
				getglobal(this:GetName().."Text"):SetTextColor(this.r, this.g, this.b)
				GameTooltip:Hide()
			</OnLeave>
		</Scripts>
	</CheckButton>

	<!-- Slider template with hover highlight -->
	<Slider name="CursiveSliderTemplate" inherits="OptionsSliderTemplate" virtual="true">
		<Scripts>
			<OnEnter>
				local text = getglobal(this:GetName().."Text")
				this.r, this.g, this.b = text:GetTextColor()
				text:SetTextColor(1, 1, 1)
				if this.tooltipText then
					GameTooltip:SetOwner(this, "ANCHOR_RIGHT")
					GameTooltip:SetText(this.tooltipText, nil, nil, nil, nil, 1)
				end
				if this.tooltipRequirement then
					GameTooltip:AddLine(this.tooltipRequirement, nil, nil, nil, 1)
					GameTooltip:Show()
				end
			</OnEnter>
			<OnLeave>
				getglobal(this:GetName().."Text"):SetTextColor(this.r, this.g, this.b)
				GameTooltip:Hide()
			</OnLeave>
		</Scripts>
	</Slider>

	<!-- ScrollFrame template with backdrop and scrollbar border -->
	<ScrollFrame name="CursiveScrollFrameTemplate" inherits="FauxScrollFrameTemplate" virtual="true">
		<Frames>
			<!-- Background frame -->
			<Frame enableMouse="false">
				<Backdrop bgFile="Interface\Tooltips\UI-Tooltip-Background" edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
					<EdgeSize val="16"/>
					<TileSize val="16"/>
					<BackgroundInsets left="5" right="5" top="5" bottom="5"/>
					<Color r="0" g="0" b="0"/>
				</Backdrop>
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset x="-6" y="8"/>
					</Anchor>
					<Anchor point="BOTTOMRIGHT">
						<Offset x="30" y="-8"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<!-- SetParent trick: reparent to grandparent so it stays visible when scrollframe hides -->
					<OnLoad>
						this:SetParent(this:GetParent():GetParent())
					</OnLoad>
				</Scripts>
			</Frame>
			<!-- Scrollbar border frame -->
			<Frame enableMouse="false">
				<Backdrop edgeFile="Interface\Buttons\UI-SliderBar-Border">
					<EdgeSize val="8"/>
				</Backdrop>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parentScrollBarScrollUpButton">
						<Offset x="-4" y="6"/>
					</Anchor>
					<Anchor point="BOTTOMRIGHT" relativeTo="$parentScrollBarScrollDownButton">
						<Offset x="4" y="-6"/>
					</Anchor>
				</Anchors>
			</Frame>
		</Frames>
	</ScrollFrame>

	<!-- List button template for ignore list / debuff list -->
	<Button name="CursiveListButtonTemplate" virtual="true" hidden="true">
		<Size x="200" y="16"/>
		<ButtonText name="$parentText">
			<Anchors>
				<Anchor point="LEFT"/>
			</Anchors>
		</ButtonText>
		<NormalFont inherits="GameFontNormalSmall"/>
		<HighlightFont inherits="GameFontHighlightSmall"/>
		<DisabledFont inherits="GameFontDisableSmall"/>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="$parentHighlight" file="Interface\QuestFrame\UI-QuestTitleHighlight" alphaMode="ADD" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT"/>
						<Anchor point="BOTTOMRIGHT"/>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>
		<Scripts>
			<OnEnter>
				getglobal(this:GetName().."Highlight"):Show()
			</OnEnter>
			<OnLeave>
				getglobal(this:GetName().."Highlight"):Hide()
			</OnLeave>
		</Scripts>
	</Button>

	<!-- Tab button template with normal/selected states -->
	<Button name="CursiveTabButtonTemplate" virtual="true">
		<Size x="100" y="32"/>
		<ButtonText name="$parentText">
			<Anchors>
				<Anchor point="CENTER">
					<Offset x="0" y="2"/>
				</Anchor>
			</Anchors>
		</ButtonText>
		<NormalFont inherits="GameFontNormal"/>
		<HighlightFont inherits="GameFontHighlight"/>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="$parentNormalTexture" file="Interface\PaperDollInfoFrame\UI-Character-InActiveTab">
					<Anchors>
						<Anchor point="TOPLEFT"/>
						<Anchor point="BOTTOMRIGHT"/>
					</Anchors>
				</Texture>
				<Texture name="$parentSelectedTexture" file="Interface\PaperDollInfoFrame\UI-Character-ActiveTab" hidden="true">
					<Anchors>
						<Anchor point="TOPLEFT"/>
						<Anchor point="BOTTOMRIGHT"/>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>
	</Button>

</Ui>
